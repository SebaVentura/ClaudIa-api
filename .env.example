PORT=3000
NODE_ENV=development

# MongoDB (scripts de migración; la API sigue en JSON hasta activar Etapa 4+)
MONGO_URI=mongodb://usuario:password@127.0.0.1:27017/nombre_db?authSource=nombre_db
# Opcional si la URI no incluye nombre de base en el path:
# MONGO_DB=nombre_db

APP_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# Rutas relativas desde server/ (local) o absolutas en producción
PRODUCTS_PATH=./data/products.json
ORDERS_PATH=./data/orders.json
CUSTOMERS_PATH=./data/customers.json

MP_ACCESS_TOKEN=
MP_ENV=sandbox

# Panel admin (JWT)
ADMIN_USER=
ADMIN_PASSWORD=
JWT_SECRET=
JWT_EXPIRES_IN=8h

# Imágenes subidas por admin (servidas en /uploads)
UPLOADS_DIR=./storage/uploads
PUBLIC_UPLOADS_BASE_URL=http://127.0.0.1:3000/uploads
