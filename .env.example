PORT=3000
NODE_ENV=development

# MongoDB (opcional en etapa inicial; requerido URI + DB juntos si se configura)
MONGODB_URI=mongodb://usuario:password@127.0.0.1:27017/nombre_db?authSource=nombre_db
MONGODB_DB=nombre_db

# Persistencia: auto | mongo | json
# auto = Mongo si conecta; si no, JSON (rollback sin tocar .env de Mongo)
STORAGE_BACKEND=auto

APP_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# Rutas relativas desde server/ (local) o absolutas en producción
PRODUCTS_PATH=./data/products.json
ORDERS_PATH=./data/orders.json
CUSTOMERS_PATH=./data/customers.json

MP_ACCESS_TOKEN=
MP_ENV=sandbox

# Panel admin (JWT)
ADMIN_USER=
ADMIN_PASSWORD=
JWT_SECRET=
JWT_EXPIRES_IN=8h

# Imágenes subidas por admin (servidas en /uploads)
UPLOADS_DIR=./storage/uploads
PUBLIC_UPLOADS_BASE_URL=http://127.0.0.1:3000/uploads
